#!/bin/bash
# dev-tracker: AI 开发状态自动追踪
# 只有 3 个命令：开始、结束、回滚
set -e

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
    DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"

usage() {
    cat <<'EOF'
用法: devtrack <命令>

命令:
  开始 | start       开始新会话（自动快照当前状态，生成 AI 上下文）
  结束 | end [摘要]  结束会话（自动保存所有变更）
  回滚 | rollback    回滚到上次会话开始前的状态

首次使用:
  初始化 | init      初始化项目追踪

辅助:
  状态 | status      查看当前状态
  帮助 | help        显示本帮助
EOF
}

if [ $# -eq 0 ]; then
    usage
    exit 0
fi

cmd="$1"
shift

case "$cmd" in
    start|开始)       exec "$SCRIPT_DIR/devtrack-start.sh" "$@" ;;
    end|结束)         exec "$SCRIPT_DIR/devtrack-end.sh" "$@" ;;
    rollback|回滚)    exec "$SCRIPT_DIR/devtrack-rollback.sh" "$@" ;;
    init|初始化)      exec "$SCRIPT_DIR/devtrack-init.sh" "$@" ;;
    status|状态)      exec "$SCRIPT_DIR/devtrack-status.sh" "$@" ;;
    hook)             exec "$SCRIPT_DIR/devtrack-hook.sh" "$@" ;;
    -h|--help|help|帮助) usage; exit 0 ;;
    *)  echo "未知命令: $cmd" >&2; usage >&2; exit 1 ;;
esac
